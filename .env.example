# Supabase / PostgreSQL (se impostato, usa Supabase per DB e per le chiavi API)
# Da Supabase: Project Settings → Database → Connection string → URI (modalità Session o Transaction)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Dopo db:push, inserisci le chiavi in Supabase (SQL Editor):
#   INSERT INTO app_config (key, value) VALUES
#     ('openai_api_key', 'sk-...'),
#     ('openapi_bearer', 'il-tuo-bearer'),
#     ('openai_chat_model', 'gpt-5.3-chat-latest');
# Oppure usa le variabili sotto (priorità a .env se non usi Supabase).
DATABASE_URL=

# Supabase Auth (email + Google). Dashboard → Settings → API per le chiavi.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Per Google: Dashboard → Authentication → Providers → Google → Enable e inserisci Client ID/Secret da Google Cloud Console.

# Where the app is served (for OAuth redirect back to the app)
FRONTEND_ORIGIN=http://localhost:3000

# Optional: API base URL if different from frontend (e.g. production API)
# API_ORIGIN=http://localhost:3000

# Chiavi API (usate se NON le metti in Supabase tabella app_config)
# OPENAI_API_KEY=
# OPENAPI_BEARER=
# OPENAI_CHAT_MODEL=gpt-5.3-chat-latest
