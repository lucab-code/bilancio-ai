# Supabase / PostgreSQL (se impostato, usa Supabase per DB e per le chiavi API)
# Da Supabase: Project Settings → Database → Connection string (copialo dalla dashboard; l'host può essere aws-1-xxx non aws-0-xxx)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres
# Dopo db:push, inserisci le chiavi in Supabase (SQL Editor):
#   INSERT INTO app_config (key, value) VALUES
#     ('openai_api_key', 'sk-...'),
#     ('openapi_bearer', 'il-tuo-bearer'),
#     ('openai_chat_model', 'gpt-5.4');
# Oppure usa le variabili sotto (priorità a .env se non usi Supabase).
DATABASE_URL=

# Supabase Auth (email + Google). Dashboard → Settings → API per le chiavi.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Google (opzionale): per abilitare "Accedi con Google" via script: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, SUPABASE_ACCESS_TOKEN (PAT).

# Where the app is served (for OAuth redirect back to the app)
FRONTEND_ORIGIN=http://localhost:3000

# Optional but strongly recommended for private internet demos:
# enables HTTP Basic Auth in front of the entire app.
# PREVIEW_BASIC_AUTH_USER=demo
# PREVIEW_BASIC_AUTH_PASS=choose-a-long-random-password

# Optional: API base URL if different from frontend (e.g. production API)
# API_ORIGIN=http://localhost:3000

# Billing / Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# BILLING_BUSINESS_ANALYSIS_CENTS=1500
# BILLING_SUBSCRIBER_EXTRA_ANALYSIS_CENTS=1200
# Stripe Price IDs per subscription plans (creare su Stripe Dashboard)
# STRIPE_PRO_PRICE_ID=price_xxx
# STRIPE_BUSINESS_PRICE_ID=price_xxx

# Chiavi API (usate se NON le metti in Supabase tabella app_config)
# OPENAI_API_KEY=
# OPENAPI_BEARER=
# OPENAPI_BEARER_SANDBOX=  (token sandbox da console.openapi.com)
# OPENAPI_USE_SANDBOX=false  (metti true solo se vuoi usare esplicitamente endpoint test.*)
# OPENAI_CHAT_MODEL=gpt-5.4
